# SecurePrint Backend Flask - Environment Configuration
# Copy this file to .env and update with your actual values

# ====================================
# Server Configuration
# ====================================
# Host to bind to (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Port to run the server on
PORT=5000

# Environment: development, staging, production
NODE_ENV=development

# Enable debug mode
DEBUG=true

# ====================================
# Database Configuration
# ====================================
# SQLite database file path
DATABASE_PATH=database.sqlite

# ====================================
# Security Configuration
# ====================================
# JWT Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_HEX_STRING

# JWT Token Expiry (in hours)
JWT_EXPIRY_HOURS=24

# JWT Refresh Token Expiry (in days)
JWT_REFRESH_EXPIRY_DAYS=7

# ====================================
# CORS Configuration
# ====================================
# Allowed origins (comma-separated for multiple)
CORS_ORIGINS=*

# ====================================
# File Upload Configuration
# ====================================
# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# Upload folder path
UPLOAD_FOLDER=uploads

# ====================================
# Logging Configuration
# ====================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# ====================================
# Instructions
# ====================================
# 1. Copy this file: copy .env.example .env (Windows) or cp .env.example .env (Linux/Mac)
# 2. Generate a secure JWT secret:
#    python -c "import secrets; print(secrets.token_hex(32))"
# 3. Update any configuration values as needed
# 4. NEVER commit the .env file to version control!
