# SecurePrint Mobile App - Environment Configuration
# Copy this file to .env and update with your actual values

# ====================================
# API Configuration
# ====================================
# Backend server URL (update with your server's IP address)
API_BASE_URL=http://10.117.97.71:5000

# API Timeout in seconds
API_TIMEOUT=30

# ====================================
# Owner Configuration
# ====================================
# Default owner ID for file uploads (get from backend after registration)
DEFAULT_OWNER_ID=owner_001

# ====================================
# App Configuration
# ====================================
# Environment: development, staging, production
APP_ENV=development

# Enable debug logging
DEBUG_MODE=true

# ====================================
# Security Configuration
# ====================================
# Encryption algorithm (AES-256-GCM is default)
ENCRYPTION_ALGORITHM=AES-256-GCM

# Key size in bits
KEY_SIZE=256
